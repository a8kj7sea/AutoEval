{
  "manifest_version": 3,
  "name": "AutoEval Classic",
  "version": "1.4",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Automate evaluation forms.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://app2.bau.edu.jo:7799/eval/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}